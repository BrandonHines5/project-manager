NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Required for adding/deleting team members from /team (auth.admin API).
# Found in Supabase dashboard → Project Settings → API → "service_role" key.
# Server-only — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional - direct read access to the CRM database (a separate Supabase
# project) for the Warranty / Rental tracker. Lets this app read CRM tables
# (rentals, projects, warranty_end_date, …) directly instead of a per-column
# API. Server-only. If unset, the tracker falls back to its local cache.
#   CRM_SUPABASE_URL              = the CRM project URL
#   CRM_SUPABASE_SERVICE_ROLE_KEY = the CRM service_role key
CRM_SUPABASE_URL=
CRM_SUPABASE_SERVICE_ROLE_KEY=

# Optional - direct read access to the HH-SpecMagician database (a separate
# Supabase project) so decision line items can link to its item catalog
# (catalog_items). Server-only. If unset, the catalog picker reports "not
# connected" and manual line items keep working.
#   SPECMAGICIAN_SUPABASE_URL              = the SpecMagician project URL
#   SPECMAGICIAN_SUPABASE_SERVICE_ROLE_KEY = its service_role key
SPECMAGICIAN_SUPABASE_URL=
SPECMAGICIAN_SUPABASE_SERVICE_ROLE_KEY=

# Optional - enables outbound email assignment notifications when both are set.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional - inbound insurance-certificate email ingestion. Create a Resend
# webhook (event `email.received`) pointed at /api/inbound/insurance and put
# its signing secret (whsec_...) here. Requires RESEND_API_KEY too (the
# webhook handler downloads attachments via the Resend API).
RESEND_WEBHOOK_SECRET=

# Master switch for AUTOMATIC insurance expiration reminders (the daily cron).
# OFF unless set to exactly "true" — leave unset/blank to keep automatic
# reminder emails to subs turned off, then set to "true" to enable them once
# the site is fully live. Does NOT affect the staff "Send request" button.
INSURANCE_REMINDERS_ENABLED=

# Optional - the Resend RECEIVING address that feeds the inbound webhook
# (e.g. insurance@<subdomain>.resend.app or a custom inbound address). Set as
# the Reply-To on insurance request/reminder emails so a sub can just hit
# Reply with their certificate attached. If unset, those emails omit the
# "reply with your certificate" suggestion (the From address can't receive).
INSURANCE_INBOUND_EMAIL=

# Required for AI features: the smart-update agent and insurance-certificate
# extraction. Server-only.
ANTHROPIC_API_KEY=

# Optional - the canonical public URL of this app. Used to build links in emails.
# Defaults to http://localhost:3000 for local dev, or Vercel's deployment URL.
NEXT_PUBLIC_APP_URL=

# Optional - Quo (OpenPhone) SMS for the "Send text to sub" button on
# schedule items. QUO_API_KEY is the workspace API key (sent verbatim as
# the Authorization header — no Bearer prefix); it also powers the Team
# page's Quo-number picker (GET /v1/phone-numbers). QUO_FROM_NUMBER is the
# SHARED FALLBACK sending number, either E.164 ("+15555555555") or a Quo
# phone-number ID ("PN..."). Team members assigned their own Quo number on
# the Team page send from it instead; everyone else falls back to this one.
# If QUO_API_KEY is unset (and no sender has a number), no text is sent.
QUO_API_KEY=
QUO_FROM_NUMBER=

# Optional - Hines Homes Dashboard sync.
# DASHBOARD_BASE_URL is used to auto-derive the per-project dashboard URL
# (project_number becomes the slug, e.g. ${DASHBOARD_BASE_URL}/projects/2026-001).
# DASHBOARD_WEBHOOK_URL receives signed POSTs on project / decision / log /
# payment events; DASHBOARD_WEBHOOK_SECRET is the shared HMAC-SHA256 secret
# used to sign the X-HH-Signature header. If any of the three is unset, the
# outbound webhook integration is a no-op (safe for previews and local dev).
DASHBOARD_BASE_URL=
DASHBOARD_WEBHOOK_URL=
DASHBOARD_WEBHOOK_SECRET=

# Optional - bearer token for INBOUND reads from the dashboard
# (GET /api/projects/available + GET /api/projects/{number}, used by the
# "Pull from dashboard" flow on the New Project page). Kept separate from
# the webhook secret so each can be rotated independently. If unset, the
# picker shows nothing and staff fall back to the "Create blank" path.
DASHBOARD_API_SECRET=

# Optional - Vercel "Protection Bypass for Automation" token. Set this
# ONLY if the dashboard's Vercel deployment has Deployment Protection
# enabled (so its production URL returns 403 to anonymous callers). With
# it set, every outbound webhook + inbound API call from PM includes
# `x-vercel-protection-bypass: <token>` so Vercel's edge lets us through.
# Leave empty if the dashboard isn't behind Deployment Protection.
DASHBOARD_PROTECTION_BYPASS=

# Quo (OpenPhone) webhook — signing secret shown when the webhook endpoint
# https://<domain>/api/inbound/quo is created in the Quo dashboard (events:
# message.received, message.delivered, call.completed,
# call.recording.completed). Unset = the endpoint rejects everything, and
# texts/calls only appear in Communications when sent through the app.
QUO_WEBHOOK_SECRET=

# Communications email reply capture. COMMS_INBOUND_EMAIL is a Resend
# receiving address (e.g. comms@updates.hineshomes.com); project-scoped app
# emails set Reply-To to comms+p_<project_id>@… so replies route back into
# the hub via /api/inbound/email-replies. COMMS_RESEND_WEBHOOK_SECRET is
# that endpoint's own Resend webhook signing secret (separate from the
# insurance one so each can be rotated independently). Both unset = replies
# go to the normal From/Reply-To and simply aren't captured.
COMMS_INBOUND_EMAIL=
COMMS_RESEND_WEBHOOK_SECRET=

# Outlook mail sync (Communications hub). App-only Graph credentials from a
# dedicated Entra app registration ("PM Mail Sync") with application
# permission Mail.Read + admin consent, scoped to PM mailboxes via an
# Exchange application access policy (New-ApplicationAccessPolicy).
# OUTLOOK_SYNC_MAILBOXES is a comma-separated list of mailboxes to sync
# (e.g. brandon@hineshomes.com,pm@hineshomes.com). All unset = the cron
# no-ops. Only mail whose counterparty matches a known contact is stored.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
OUTLOOK_SYNC_MAILBOXES=

# Shared mailbox used as the Graph sender for automated mail (crons,
# token-page notifications) when no staff user triggered the send — e.g.
# office@hineshomes.com. Must be inside the application access policy group.
# Unset = automated mail keeps going out via Resend.
MS_SYSTEM_MAILBOX=
